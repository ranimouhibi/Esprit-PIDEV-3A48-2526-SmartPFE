<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.CandidatureCompareController">
    <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

    <top>
        <VBox spacing="4">
            <Label text="Candidature Comparison" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Side-by-side comparison of selected candidates. Best match highlighted in green."
                   style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
            <padding><Insets bottom="10"/></padding>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f4f6fb; -fx-background: #f4f6fb;">
            <HBox fx:id="compareContainer" spacing="16">
                <padding><Insets top="8" bottom="8"/></padding>
            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
