<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.MeetingReportDetailDialogController"
      spacing="0" style="-fx-background-color: #f0f2f5;">

    <!-- Header -->
    <VBox style="-fx-background-color: #1e1e2e;" spacing="6">
        <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Détails du Report" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBadge" text="DRAFT"/>
        </HBox>
        <Label fx:id="headerSub" text="" style="-fx-font-size: 12px; -fx-text-fill: #8b8fa8;"/>
    </VBox>

    <!-- Content -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="12">
            <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10;" spacing="12">
                <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>
                <HBox spacing="20">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Projet" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="detailProject" text="—" style="-fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Type Meeting" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="detailType" text="—" style="-fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    </VBox>
                </HBox>
                <HBox spacing="20">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Créé par" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="detailCreatedBy" text="—" style="-fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Date du meeting" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="detailMeetingDate" text="—" style="-fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                    </VBox>
                </HBox>
                <VBox spacing="4">
                    <Label text="Créé le" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    <Label fx:id="detailCreatedAt" text="—" style="-fx-text-fill: #374151;"/>
                </VBox>
                <Separator/>
                <VBox spacing="4">
                    <Label text="Points de discussion" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    <Label fx:id="detailDiscussion" text="—" style="-fx-text-fill: #374151;" wrapText="true"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Décisions" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    <Label fx:id="detailDecisions" text="—" style="-fx-text-fill: #374151;" wrapText="true"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Action Items" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    <Label fx:id="detailActionItems" text="—" style="-fx-text-fill: #374151;" wrapText="true"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Prochaines étapes" style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
                    <Label fx:id="detailNextSteps" text="—" style="-fx-text-fill: #374151;" wrapText="true"/>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;">
        <padding><Insets top="14" bottom="14" left="24" right="24"/></padding>
        <Button fx:id="closeBtn" text="Fermer" onAction="#handleClose"
                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 24;"/>
    </HBox>
</VBox>
