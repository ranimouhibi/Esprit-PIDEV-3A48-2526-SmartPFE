<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.UserController">
    <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

    <top>
        <VBox spacing="10">
            <Label text="User Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search..." prefWidth="200"/>
                <Button text="🔍" onAction="#handleSearch" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <ComboBox fx:id="roleFilterCombo" promptText="Filter by role"/>
                <Button text="Filter" onAction="#handleFilter" style="-fx-background-color: #06D6A0; -fx-text-fill: white; -fx-background-radius: 6;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.6">
            <TableView fx:id="userTable">
                <columns>
                    <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                    <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
                    <TableColumn fx:id="colActive" text="Active" prefWidth="70"/>
                </columns>
            </TableView>

            <ScrollPane fitToWidth="true">
                <VBox spacing="10">
                    <padding><Insets top="10" left="15" right="15" bottom="10"/></padding>
                    <Label text="User Form" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Label text="Name *"/>
                    <TextField fx:id="nameField" promptText="Full name"/>

                    <Label text="Email *"/>
                    <TextField fx:id="emailField" promptText="email@example.com"/>

                    <Label text="Password"/>
                    <PasswordField fx:id="passwordField" promptText="Leave empty to keep unchanged"/>

                    <Label text="Phone"/>
                    <TextField fx:id="phoneField" promptText="+216 XX XXX XXX"/>

                    <Label text="Role *"/>
                    <ComboBox fx:id="roleCombo" maxWidth="Infinity"/>

                    <CheckBox fx:id="activeCheck" text="Active account" selected="true"/>

                    <Label fx:id="messageLabel" text="" wrapText="true"/>

                    <HBox spacing="10">
                        <Button text="💾 Save" onAction="#handleSave" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button text="🗑 Delete" onAction="#handleDelete" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #FF6B6B; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button text="✖ Clear" onAction="#handleClear" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #aaa; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
