<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.SprintController"
      spacing="0" style="-fx-background-color: #f4f6fb;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Sprints Management" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>
            <Label text="Plan, track and manage all project sprints" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
        </VBox>
        <HBox spacing="10">
            <Button text="📅 Calendar"   onAction="#handleCalendar"
                    style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Button text="📊 Statistics" onAction="#handleStats"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Button text="📄 Export PDF" onAction="#handleExportPdf"
                    style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Button text="➕ New Sprint" onAction="#handleAddDialog"
                    style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand; -fx-font-size: 12px;"/>
        </HBox>
    </HBox>

    <!-- Stats Bar -->
    <HBox spacing="0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="16" bottom="16" left="30" right="30"/></padding>

        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 12 24;">
            <Label fx:id="statTotal" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>
            <Label text="Total" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #f59e0b22; -fx-background-radius: 8; -fx-padding: 12 24;">
            <Label fx:id="statPlanned" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
            <Label text="Planned" style="-fx-font-size: 10px; -fx-text-fill: #f59e0b;"/>
        </VBox>

        <Region prefWidth="12"/>

        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #10b98122; -fx-background-radius: 8; -fx-padding: 12 24;">
            <Label fx:id="statActive" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
            <Label text="Active" style="-fx-font-size: 10px; -fx-text-fill: #10b981;"/>
        </VBox>

        <Region prefWidth="12"/>

        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #6b728022; -fx-background-radius: 8; -fx-padding: 12 24;">
            <Label fx:id="statClosed" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #6b7280;"/>
            <Label text="Closed" style="-fx-font-size: 10px; -fx-text-fill: #6b7280;"/>
        </VBox>
    </HBox>

    <!-- Search & Filter Bar -->
    <HBox spacing="12" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="14" bottom="14" left="30" right="30"/></padding>
        <TextField fx:id="searchField" promptText="Search sprints..." prefWidth="260"
                   style="-fx-pref-height: 38px; -fx-background-radius: 19; -fx-border-radius: 19; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-padding: 0 16;"/>
        <DatePicker fx:id="fromDate" promptText="From date" prefWidth="140"
                    style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8;"/>
        <DatePicker fx:id="toDate" promptText="To date" prefWidth="140"
                    style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8;"/>
        <Button text="Filter" onAction="#handleSort"
                style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        <Button text="Clear" onAction="#handleClearFilter"
                style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="messageLabel" text="" wrapText="true" style="-fx-font-size: 12px;"/>
    </HBox>

    <!-- Sprint Cards Grid -->
    <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="20">
            <padding><Insets top="24" bottom="24" left="30" right="30"/></padding>
            <FlowPane fx:id="cardPane" hgap="20" vgap="20" prefWrapLength="1000"/>
        </VBox>
    </ScrollPane>

</VBox>
