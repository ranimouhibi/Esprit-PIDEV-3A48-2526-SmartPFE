<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.SprintController"
            style="-fx-background-color: #f4f6fb;">
    <padding><Insets top="28" left="32" right="32" bottom="28"/></padding>

    <top>
        <VBox spacing="14">
            <padding><Insets bottom="8"/></padding>
            <Label text="Sprints" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                <Button text="New Sprint"   onAction="#handleAddDialog"  minWidth="110"
                        style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 9 18; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Edit"         onAction="#handleEditDialog" minWidth="80"
                        style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 9 18; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Delete"       onAction="#handleDelete"     minWidth="80"
                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 9 18; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Statistics"   onAction="#handleStats"      minWidth="100"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 9 18; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Export PDF"   onAction="#handleExportPdf"  minWidth="110"
                        style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 9 18; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Search sprints..." prefWidth="230"
                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e5e7eb; -fx-padding: 8 12; -fx-background-color: #f9fafb;"/>
                <Label fx:id="messageLabel" text="" wrapText="true" style="-fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);">
            <padding><Insets top="6" left="6" right="6" bottom="6"/></padding>
            <TableView fx:id="sprintTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-table-cell-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"      prefWidth="60"/>
                    <TableColumn fx:id="colNumber"  text="#"       prefWidth="60"/>
                    <TableColumn fx:id="colName"    text="Name"    prefWidth="230"/>
                    <TableColumn fx:id="colStatus"  text="Status"  prefWidth="110"/>
                    <TableColumn fx:id="colProject" text="Project" prefWidth="210"/>
                    <TableColumn fx:id="colStart"   text="Start"   prefWidth="120"/>
                    <TableColumn fx:id="colEnd"     text="End"     prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="No sprints found." style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>
