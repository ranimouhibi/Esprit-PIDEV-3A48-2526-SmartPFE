<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.AuditLogController"
      spacing="0" style="-fx-background-color: #f4f6fb;">

    <padding><Insets top="28" left="32" right="32" bottom="28"/></padding>

    <!-- Header -->
    <VBox spacing="4">
        <Label text="Audit Log" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
        <Label text="Track all system activity and user actions" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
    </VBox>

    <!-- Toolbar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <padding><Insets top="20" bottom="16"/></padding>

        <TextField fx:id="searchField" promptText="Search user, IP, details…"
                   prefWidth="260" prefHeight="38"
                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: white; -fx-padding: 0 12; -fx-font-size: 13px;"/>

        <ComboBox fx:id="actionFilter" promptText="All actions" prefHeight="38" prefWidth="160"
                  style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: white; -fx-font-size: 13px;"/>

        <Button text="Search" onAction="#handleSearch" prefHeight="38"
                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 0 20; -fx-cursor: hand;"/>

        <Button text="Reset" onAction="#handleReset" prefHeight="38"
                style="-fx-background-color: #e5e7eb; -fx-text-fill: #333; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 0 16; -fx-cursor: hand;"/>

        <HBox HBox.hgrow="ALWAYS"/>

        <Label fx:id="countLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);">

        <TableView fx:id="auditTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background-radius: 14;">
            <columns>
                <TableColumn fx:id="colDate"    text="Date / Time"  prefWidth="160" minWidth="140"/>
                <TableColumn fx:id="colUser"    text="User"         prefWidth="160" minWidth="120"/>
                <TableColumn fx:id="colAction"  text="Action"       prefWidth="130" minWidth="100"/>
                <TableColumn fx:id="colIp"      text="IP Address"   prefWidth="130" minWidth="100"/>
                <TableColumn fx:id="colDetails" text="Details"      prefWidth="380" minWidth="200"/>
            </columns>
            <placeholder>
                <Label text="No audit log entries found." style="-fx-text-fill: #aaa; -fx-font-size: 13px;"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>
