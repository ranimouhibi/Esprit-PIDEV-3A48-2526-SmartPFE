<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.OfferCalendarController"
      spacing="0" style="-fx-background-color: #f4f6fb;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="16" bottom="16" left="24" right="24"/></padding>
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Offers &amp; Candidatures Calendar"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Deadlines, applications and interviews"
                   style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
        </VBox>
        <!-- Legend -->
        <HBox spacing="16" alignment="CENTER">
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Label text="●" style="-fx-text-fill: #a12c2f; -fx-font-size: 14px;"/>
                <Label text="Deadline" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
            </HBox>
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Label text="●" style="-fx-text-fill: #667eea; -fx-font-size: 14px;"/>
                <Label text="Application" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
            </HBox>
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Label text="●" style="-fx-text-fill: #22c55e; -fx-font-size: 14px;"/>
                <Label text="Accepted" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
            </HBox>
            <HBox spacing="5" alignment="CENTER_LEFT">
                <Label text="●" style="-fx-text-fill: #8b5cf6; -fx-font-size: 14px;"/>
                <Label text="Interview" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
            </HBox>
            <Button text="↻ Refresh" onAction="#handleRefresh"
                    style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 7 16; -fx-cursor: hand; -fx-font-size: 11px;"/>
        </HBox>
    </HBox>

    <!-- FullCalendar WebView -->
    <WebView fx:id="calendarWebView" VBox.vgrow="ALWAYS"/>

</VBox>
