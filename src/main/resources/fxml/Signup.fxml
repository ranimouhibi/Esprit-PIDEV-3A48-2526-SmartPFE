<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.controller.SignupController"
           style="-fx-background-color: #2d2d2d;">

    <ScrollPane fitToWidth="true" fitToHeight="true"
                style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">

        <VBox alignment="CENTER" style="-fx-background-color: #2d2d2d;" minHeight="700">
            <padding><Insets top="40" bottom="40"/></padding>

            <VBox alignment="CENTER" spacing="0" maxWidth="420"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 5);">
                <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

                <!-- Header -->
                <VBox spacing="8" alignment="CENTER">
                    <Label text="Smart-PFE" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #a12c2f;"/>
                    <Label text="Create your account" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
                </VBox>

                <VBox spacing="16">
                    <padding><Insets top="28"/></padding>

                    <!-- Full Name -->
                    <VBox spacing="6">
                        <Label text="Full Name" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                        <TextField fx:id="nameField" promptText="John Doe"
                                   style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
                        <Label fx:id="nameError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" managed="false" visible="false"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="6">
                        <Label text="Email" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                        <TextField fx:id="emailField" promptText="name@example.com"
                                   style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
                        <Label fx:id="emailError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" managed="false" visible="false"/>
                    </VBox>

                    <!-- Phone -->
                    <VBox spacing="6">
                        <Label text="Phone" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                        <TextField fx:id="phoneField" promptText="+213 6XX XXX XXX"
                                   style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
                        <Label fx:id="phoneError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" managed="false" visible="false"/>
                    </VBox>

                    <!-- Role -->
                    <VBox spacing="6">
                        <Label text="Role" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                        <ComboBox fx:id="roleCombo" promptText="Select your role" maxWidth="Infinity"
                                  style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-font-size: 13px;"/>
                        <Label fx:id="roleError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" managed="false" visible="false"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="6">
                        <Label text="Password" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                        <PasswordField fx:id="passwordField" promptText="Min. 8 characters"
                                       style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
                        <Label fx:id="passwordError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" managed="false" visible="false"/>
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="6">
                        <Label text="Confirm Password" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Repeat your password"
                                       style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
                        <Label fx:id="confirmPasswordError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" managed="false" visible="false"/>
                    </VBox>

                    <!-- Global error -->
                    <Label fx:id="globalError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" alignment="CENTER" managed="false" visible="false"/>

                    <!-- Sign Up Button -->
                    <Button fx:id="signupButton" text="Create Account" onAction="#handleSignup"
                            maxWidth="Infinity" prefHeight="46"
                            style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 23; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(161,44,47,0.3), 8, 0, 0, 2);"/>

                    <!-- Back to login -->
                    <HBox alignment="CENTER" spacing="4">
                        <padding><Insets top="4"/></padding>
                        <Label text="Already have an account?" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                        <Label fx:id="loginLink" text="Sign in" onMouseClicked="#goToLogin"
                               style="-fx-text-fill: #a12c2f; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    </HBox>

                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>

</StackPane>
