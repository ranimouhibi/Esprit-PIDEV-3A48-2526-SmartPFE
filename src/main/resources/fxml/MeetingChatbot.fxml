<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.MeetingChatbotController"
      spacing="0" style="-fx-background-color:#1e1e2e;" prefWidth="480" prefHeight="580">

    <!-- Header -->
    <VBox style="-fx-background-color:#2a2a3e;" spacing="4">
        <padding><Insets top="16" bottom="16" left="20" right="20"/></padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="🤖 Meeting Assistant" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeBtn" text="✕" onAction="#handleClose"
                    style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-background-radius:6;-fx-cursor:hand;-fx-padding:4 10;"/>
        </HBox>
        <Label text="Posez vos questions sur vos meetings en langage naturel"
               style="-fx-font-size:11px;-fx-text-fill:#8b8fa8;"/>
    </VBox>

    <!-- Chat area -->
    <ScrollPane fx:id="chatScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-background:#1e1e2e;-fx-border-color:transparent;">
        <VBox fx:id="chatContainer" spacing="4" style="-fx-background-color:#1e1e2e;">
            <padding><Insets top="12" bottom="12" left="4" right="4"/></padding>
        </VBox>
    </ScrollPane>

    <!-- Status -->
    <Label fx:id="statusLabel" text="" style="-fx-text-fill:#8b8fa8;-fx-font-size:11px;-fx-padding:0 16;"/>

    <!-- Input area -->
    <HBox spacing="8" style="-fx-background-color:#2a2a3e;-fx-border-color:#3a3a4e;-fx-border-width:1 0 0 0;">
        <padding><Insets top="12" bottom="12" left="16" right="16"/></padding>
        <TextField fx:id="questionField" HBox.hgrow="ALWAYS"
                   promptText="Posez votre question..."
                   style="-fx-background-color:#1e1e2e;-fx-text-fill:white;-fx-prompt-text-fill:#555;
                          -fx-background-radius:20;-fx-border-color:#444;-fx-border-radius:20;-fx-padding:8 14;"/>
        <Button fx:id="sendBtn" text="Envoyer" onAction="#handleSend"
                style="-fx-background-color:#a12c2f;-fx-text-fill:white;-fx-font-weight:bold;
                       -fx-background-radius:20;-fx-cursor:hand;-fx-padding:8 18;"/>
    </HBox>
</VBox>
