<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.MeetingFormDialogController"
      spacing="0" style="-fx-background-color: #f0f2f5;">

    <!-- Header -->
    <VBox style="-fx-background-color: #1e1e2e;" spacing="4">
        <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>
        <Label fx:id="dialogTitle" text="Meeting" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </VBox>

    <!-- Form -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="14">
            <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>

            <VBox spacing="4">
                <Label text="Projet *" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="projectCombo" maxWidth="Infinity"
                          style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db;"/>
            </VBox>

            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Type *" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ComboBox fx:id="typeCombo" maxWidth="Infinity"
                              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Statut" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ComboBox fx:id="statusCombo" maxWidth="Infinity"
                              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db;"/>
                </VBox>
            </HBox>

            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Date *" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity"
                                style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Durée (min) *" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <TextField fx:id="durationField" promptText="ex: 60"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db; -fx-padding: 7 10;"/>
                </VBox>
            </HBox>

            <VBox spacing="4">
                <Label text="Lieu * (non requis si ONLINE)" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="locationField" promptText="Salle de réunion, adresse..."
                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db; -fx-padding: 7 10;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Lien (ONLINE/HYBRID)" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="linkField" promptText="https://..."
                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db; -fx-padding: 7 10;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Agenda" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextArea fx:id="agendaField" prefRowCount="3" promptText="Points à aborder..."
                          style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db; -fx-padding: 7 10;"/>
            </VBox>

            <!-- Participants -->
            <VBox spacing="4">
                <Label text="Participants (Ctrl+clic pour sélection multiple)" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ListView fx:id="participantsListView" prefHeight="160"
                          style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #d1d5db;"/>
                <Label text="Les participants sélectionnés recevront un email d'invitation."
                       style="-fx-text-fill: #6b7280; -fx-font-size: 11px;"/>
            </VBox>

            <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;">
        <padding><Insets top="14" bottom="14" left="24" right="24"/></padding>
        <Button text="Annuler" onAction="#handleCancel"
                style="-fx-background-color: #f3f4f6; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20;"/>
        <Button fx:id="saveBtn" text="Enregistrer" onAction="#handleSave"
                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20; -fx-font-weight: bold;"/>
    </HBox>
</VBox>
