<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.MeetingStatsDialogController"
      spacing="0" style="-fx-background-color: #f0f2f5;">

    <!-- Header -->
    <VBox style="-fx-background-color: #1e1e2e;" spacing="4">
        <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>
        <Label text="Statistiques Meetings" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="Vue d'ensemble de vos réunions" style="-fx-font-size: 12px; -fx-text-fill: #8b8fa8;"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="16">
            <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>

            <!-- Row 1 -->
            <HBox spacing="12">
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #2a2a3e; -fx-background-radius: 10;">
                    <padding><Insets top="16" bottom="16" left="12" right="12"/></padding>
                    <Label text="TOTAL" style="-fx-font-size: 10px; -fx-text-fill: #8b8fa8;"/>
                    <Label fx:id="statTotal" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #2a2a3e; -fx-background-radius: 10;">
                    <padding><Insets top="16" bottom="16" left="12" right="12"/></padding>
                    <Label text="UPCOMING" style="-fx-font-size: 10px; -fx-text-fill: #8b8fa8;"/>
                    <Label fx:id="statUpcoming" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #2a2a3e; -fx-background-radius: 10;">
                    <padding><Insets top="16" bottom="16" left="12" right="12"/></padding>
                    <Label text="DURÉE MOY." style="-fx-font-size: 10px; -fx-text-fill: #8b8fa8;"/>
                    <Label fx:id="statAvgDuration" text="0 min" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #06D6A0;"/>
                </VBox>
            </HBox>

            <!-- Row 2: Status -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10;" spacing="10">
                <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>
                <Label text="Par Statut" style="-fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                <HBox spacing="12">
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #fff8e1; -fx-background-radius: 8;">
                        <padding><Insets top="12" bottom="12" left="8" right="8"/></padding>
                        <Label text="PENDING" style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="statPending" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #e8f5e9; -fx-background-radius: 8;">
                        <padding><Insets top="12" bottom="12" left="8" right="8"/></padding>
                        <Label text="CONFIRMED" style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="statConfirmed" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #fce4e4; -fx-background-radius: 8;">
                        <padding><Insets top="12" bottom="12" left="8" right="8"/></padding>
                        <Label text="CANCELLED" style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="statCancelled" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Row 3: Type -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10;" spacing="10">
                <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>
                <Label text="Par Type" style="-fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                <HBox spacing="12">
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #e8eaf6; -fx-background-radius: 8;">
                        <padding><Insets top="12" bottom="12" left="8" right="8"/></padding>
                        <Label text="ONLINE" style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="statOnline" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #e0f7fa; -fx-background-radius: 8;">
                        <padding><Insets top="12" bottom="12" left="8" right="8"/></padding>
                        <Label text="IN_PERSON" style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="statInPerson" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #00acc1;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #f3e5f5; -fx-background-radius: 8;">
                        <padding><Insets top="12" bottom="12" left="8" right="8"/></padding>
                        <Label text="HYBRID" style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                        <Label fx:id="statHybrid" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Monthly -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 10;" spacing="10">
                <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>
                <Label text="Par Mois (6 derniers mois)" style="-fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                <ListView fx:id="monthList" prefHeight="140"
                          style="-fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;"/>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;">
        <padding><Insets top="14" bottom="14" left="24" right="24"/></padding>
        <Button fx:id="closeBtn" text="Fermer" onAction="#handleClose"
                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 24;"/>
    </HBox>
</VBox>
