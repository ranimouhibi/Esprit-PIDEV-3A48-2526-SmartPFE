<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ProjectDocumentsDialogController"
      spacing="0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 25, 0, 0, 5);">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #2d2d2d; -fx-background-radius: 16 16 0 0; -fx-padding: 20 24;">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Project Documents" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="projectNameLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #bbb;"/>
        </VBox>
        <Button fx:id="uploadBtn" text="+ Upload Document" onAction="#handleToggleForm"
                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 12px;"/>
    </HBox>

    <!-- Upload Form (hidden by default) -->
    <VBox fx:id="uploadFormContainer" visible="false" managed="false" spacing="14"
          style="-fx-background-color: #f0f4ff; -fx-border-color: #667eea; -fx-border-width: 0 0 0 4;">
        <padding><Insets top="18" bottom="18" left="24" right="24"/></padding>

        <Label text="Upload New Document" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>

        <!-- File selection -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="filePathField" promptText="No file selected..." prefWidth="340"
                       style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1.5;"
                       editable="false"/>
            <Button text="Browse..." onAction="#handleBrowseFile"
                    style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18; -fx-cursor: hand; -fx-pref-height: 38px;"/>
        </HBox>
        <Label fx:id="fileError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 10px; -fx-font-weight: bold;"/>

        <!-- Category and Description -->
        <HBox spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Category *" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #333;"/>
                <ComboBox fx:id="categoryCombo" promptText="Select category" maxWidth="Infinity"
                          style="-fx-pref-height: 36px; -fx-background-radius: 8;"/>
                <Label fx:id="categoryError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Description" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #333;"/>
                <TextField fx:id="descriptionField" promptText="Optional description"
                           style="-fx-pref-height: 36px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1.5;"/>
            </VBox>
        </HBox>

        <!-- Actions -->
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Cancel" onAction="#handleCancelUpload"
                    style="-fx-background-color: #f3f4f6; -fx-text-fill: #666; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Button text="Upload" onAction="#handleUpload"
                    style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-font-size: 12px;"/>
        </HBox>
    </VBox>

    <!-- Filter bar -->
    <HBox spacing="10" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 12 24;">
        <ComboBox fx:id="filterCategory" promptText="All Categories" prefWidth="180"
                  style="-fx-pref-height: 36px; -fx-background-radius: 8;"/>
        <Button text="Reset" onAction="#handleReset"
                style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18; -fx-cursor: hand; -fx-pref-height: 36px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" text="" style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
    </HBox>

    <!-- Documents list -->
    <ScrollPane fitToWidth="true" prefHeight="400" prefWidth="720" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: #f9fafb; -fx-border-color: transparent;">
        <VBox fx:id="docsContainer" spacing="10" style="-fx-background-color: #f9fafb;">
            <padding><Insets top="16" bottom="16" left="24" right="24"/></padding>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 16 16;">
        <padding><Insets top="14" bottom="14" left="24" right="24"/></padding>
        <Button text="Close" onAction="#handleClose"
                style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 28; -fx-cursor: hand; -fx-font-size: 13px;"/>
    </HBox>

</VBox>
