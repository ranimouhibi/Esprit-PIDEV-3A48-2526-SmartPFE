<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.MeetingController"
      spacing="0" style="-fx-background-color: #f4f6fb;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Meetings Management" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>
            <Label text="View and manage all meetings in the system" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
        </VBox>
        <Button text="📅 Calendar" onAction="#handleCalendar"
                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 12px;"/>
    </HBox>

    <!-- Stats Bar -->
    <HBox spacing="0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="16" bottom="16" left="30" right="30"/></padding>
        
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 12 20;">
            <Label fx:id="statTotal" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>
            <Label text="Total" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
        </VBox>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #FFA50022; -fx-background-radius: 8; -fx-padding: 12 20;">
            <Label fx:id="statPending" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FFA500;"/>
            <Label text="Pending" style="-fx-font-size: 10px; -fx-text-fill: #FFA500;"/>
        </VBox>
        
        <Region prefWidth="12"/>
        
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #4CAF5022; -fx-background-radius: 8; -fx-padding: 12 20;">
            <Label fx:id="statConfirmed" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
            <Label text="Confirmed" style="-fx-font-size: 10px; -fx-text-fill: #4CAF50;"/>
        </VBox>
        
        <Region prefWidth="12"/>
        
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #F4433622; -fx-background-radius: 8; -fx-padding: 12 20;">
            <Label fx:id="statCancelled" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #F44336;"/>
            <Label text="Cancelled" style="-fx-font-size: 10px; -fx-text-fill: #F44336;"/>
        </VBox>
        
        <Region prefWidth="12"/>
        
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #667eea22; -fx-background-radius: 8; -fx-padding: 12 20;">
            <Label fx:id="statUpcoming" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
            <Label text="Upcoming" style="-fx-font-size: 10px; -fx-text-fill: #667eea;"/>
        </VBox>
    </HBox>

    <!-- Search & Filter -->
    <HBox spacing="12" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="16" bottom="16" left="30" right="30"/></padding>
        <TextField fx:id="searchField" promptText="Search meetings..." prefWidth="280"
                   style="-fx-pref-height: 38px; -fx-background-radius: 19; -fx-border-radius: 19; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-padding: 0 16;"/>
        <ComboBox fx:id="filterType" promptText="All Types" prefWidth="130"
                  style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8;"/>
        <ComboBox fx:id="filterStatus" promptText="All Status" prefWidth="150"
                  style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8;"/>
        <ComboBox fx:id="sortCombo" promptText="Sort by" prefWidth="180"
                  style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8;"/>
        <Button text="Reset" onAction="#handleReset"
                style="-fx-background-color: #4b5563; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🤖 Ask AI" onAction="#handleChatbot"
                style="-fx-background-color: #374151; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        <Button text="📊 Stats" onAction="#handleStats"
                style="-fx-background-color: #4b5563; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        <Button text="➕ New Meeting" onAction="#handleAdd"
                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
    </HBox>

    <!-- Meetings Grid -->
    <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="20">
            <padding><Insets top="24" bottom="24" left="30" right="30"/></padding>
            <FlowPane fx:id="meetingsContainer" hgap="20" vgap="20" prefWrapLength="1000"/>
        </VBox>
    </ScrollPane>

</VBox>
