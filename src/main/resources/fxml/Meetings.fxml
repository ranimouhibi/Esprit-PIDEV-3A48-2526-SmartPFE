<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      spacing="0" style="-fx-background-color: #f4f6fb;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Meetings" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>
            <Label text="Schedule and manage your project meetings" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
        </VBox>
    </HBox>

    <!-- Content -->
    <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="20" alignment="CENTER">
            <padding><Insets top="80" bottom="80" left="30" right="30"/></padding>
            
            <Label text="[M]" style="-fx-font-size: 64px; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
            <Label text="Meetings Feature" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>
            <Label text="This feature is coming soon!" style="-fx-font-size: 14px; -fx-text-fill: #888;"/>
            <Label text="You will be able to schedule and manage all project meetings here." 
                   style="-fx-font-size: 13px; -fx-text-fill: #999; -fx-text-alignment: center;" 
                   wrapText="true" maxWidth="400"/>
        </VBox>
    </ScrollPane>

</VBox>
