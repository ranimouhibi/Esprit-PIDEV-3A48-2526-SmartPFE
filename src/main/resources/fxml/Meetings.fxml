<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.MeetingController">
    <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

    <top>
        <Label text="Gestion des Meetings" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    </top>

    <center>
        <SplitPane dividerPositions="0.6">
            <TableView fx:id="meetingTable">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="130"/>
                    <TableColumn fx:id="colStatus" text="Statut" prefWidth="100"/>
                    <TableColumn fx:id="colProject" text="Projet" prefWidth="160"/>
                    <TableColumn fx:id="colDate" text="Date planifiée" prefWidth="150"/>
                </columns>
            </TableView>

            <ScrollPane fitToWidth="true">
                <VBox spacing="10">
                    <padding><Insets top="10" left="15" right="15" bottom="10"/></padding>
                    <Label text="Formulaire Meeting" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Label text="Projet *"/>
                    <ComboBox fx:id="projectCombo" maxWidth="Infinity"/>

                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Type"/>
                            <ComboBox fx:id="typeCombo" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Statut"/>
                            <ComboBox fx:id="statusCombo" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <Label text="Date planifiée"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity"/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Durée (min)"/>
                        <Spinner fx:id="durationSpinner" prefWidth="100"/>
                        <CheckBox fx:id="onlineCheck" text="En ligne"/>
                    </HBox>

                    <Label text="Lieu"/>
                    <TextField fx:id="locationField"/>

                    <Label text="Lien (online)"/>
                    <TextField fx:id="linkField"/>

                    <Label text="Agenda"/>
                    <TextArea fx:id="agendaField" prefRowCount="2"/>

                    <Label text="Notes"/>
                    <TextArea fx:id="notesField" prefRowCount="2"/>

                    <Label fx:id="messageLabel" text="" wrapText="true"/>

                    <HBox spacing="10">
                        <Button text="💾 Sauvegarder" onAction="#handleSave" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button text="🗑 Supprimer" onAction="#handleDelete" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #FF6B6B; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button text="✖ Effacer" onAction="#handleClear" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #aaa; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
