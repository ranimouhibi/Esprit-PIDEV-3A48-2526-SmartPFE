<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.controller.ResetPasswordController"
           style="-fx-background-color: #2d2d2d;">

    <VBox alignment="CENTER" spacing="0" maxWidth="380"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 5);">
        <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

        <!-- Header -->
        <VBox spacing="8" alignment="CENTER">
            <Label text="Smart-PFE" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #a12c2f;"/>
            <Label text="Enter your reset code" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
        </VBox>

        <VBox spacing="18">
            <padding><Insets top="30"/></padding>

            <Label fx:id="instructionLabel"
                   text="A 6-digit code was sent to your email. Enter it below along with your new password."
                   style="-fx-font-size: 12px; -fx-text-fill: #666;" wrapText="true" alignment="CENTER"/>

            <!-- OTP Code -->
            <VBox spacing="8">
                <Label text="Reset Code" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                <TextField fx:id="otpField" promptText="6-digit code"
                           style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 16px; -fx-alignment: CENTER; -fx-font-weight: bold;"/>
                <Label fx:id="otpError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" visible="false" managed="false"/>
            </VBox>

            <!-- New Password -->
            <VBox spacing="8">
                <Label text="New Password" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                <PasswordField fx:id="newPassField" promptText="Min. 8 chars, 1 uppercase, 1 digit"
                               style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
                <Label fx:id="newPassError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" visible="false" managed="false"/>
            </VBox>

            <!-- Confirm Password -->
            <VBox spacing="8">
                <Label text="Confirm Password" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                <PasswordField fx:id="confirmPassField" promptText="Repeat new password"
                               style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
                <Label fx:id="confirmPassError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" visible="false" managed="false"/>
            </VBox>

            <Label fx:id="feedbackLabel" text="" wrapText="true" alignment="CENTER"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;" visible="false" managed="false"/>

            <Button text="Reset Password" onAction="#handleResetPassword"
                    maxWidth="Infinity" prefHeight="46"
                    style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 23; -fx-cursor: hand;"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Back to" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                <Label text="Sign in" onMouseClicked="#goToLogin"
                       style="-fx-text-fill: #a12c2f; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </VBox>

</StackPane>
