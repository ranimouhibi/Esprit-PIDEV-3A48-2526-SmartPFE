<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.controller.ApplyDialogController"
           style="-fx-background-color: rgba(0,0,0,0.45);">

    <VBox alignment="CENTER">
        <!-- Dialog Card -->
        <VBox fx:id="dialogCard" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 18;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 32, 0, 0, 8);"
              maxWidth="580" minWidth="520">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #a12c2f, #c0392b);
                         -fx-background-radius: 18 18 0 0; -fx-padding: 20 24;">
                <Label text="📝" style="-fx-font-size: 22px;"/>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Submit Application" style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="offerTitleLabel" text=""
                           style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.75);"/>
                </VBox>
                <Button text="✕" onAction="#handleClose"
                        style="-fx-background-color: rgba(255,255,255,0.18); -fx-text-fill: white;
                               -fx-background-radius: 20; -fx-font-size: 13px; -fx-cursor: hand;
                               -fx-padding: 4 9; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Body -->
            <VBox spacing="16" style="-fx-padding: 24 28;">

                <!-- Motivation Letter -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label text="Motivation Letter" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #333;"/>
                        <Label text="*" style="-fx-text-fill: #a12c2f; -fx-font-weight: bold;"/>
                    </HBox>
                    <TextArea fx:id="motivationField"
                              promptText="Explain why you are the ideal candidate for this position... (min. 50 characters)"
                              prefRowCount="4" wrapText="true"
                              style="-fx-background-radius: 10; -fx-border-radius: 10;
                                     -fx-border-color: #e0e0e0; -fx-border-width: 1.5;
                                     -fx-font-size: 12px; -fx-padding: 10;"/>
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="motivationError" text=""
                               style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="motivationCount" text="0 / 2000"
                               style="-fx-text-fill: #aaa; -fx-font-size: 10px;"/>
                    </HBox>
                </VBox>

                <!-- CV + Portfolio row -->
                <HBox spacing="16">
                    <!-- CV -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label text="CV / Resume" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #333;"/>
                            <Label text="*" style="-fx-text-fill: #a12c2f; -fx-font-weight: bold;"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <VBox fx:id="cvDropZone" alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: #fafafa; -fx-border-color: #ddd;
                                         -fx-border-width: 2; -fx-border-style: dashed;
                                         -fx-border-radius: 10; -fx-background-radius: 10;
                                         -fx-padding: 10 14; -fx-cursor: hand;"
                                  onMouseClicked="#handleBrowseCV">
                                <Label fx:id="cvIcon" text="📄" style="-fx-font-size: 18px;"/>
                                <Label fx:id="cvFileName" text="Click to browse"
                                       style="-fx-font-size: 10px; -fx-text-fill: #888;"/>
                            </VBox>
                        </HBox>
                        <Label fx:id="cvError" text="" style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Portfolio -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Portfolio URL" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #333;"/>
                        <TextField fx:id="portfolioField" promptText="https://your-portfolio.com"
                                   style="-fx-pref-height: 36px; -fx-background-radius: 10;
                                          -fx-border-radius: 10; -fx-border-color: #e0e0e0;
                                          -fx-border-width: 1.5; -fx-font-size: 12px;"/>
                        <Label text="GitHub URL" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #333;"/>
                        <TextField fx:id="githubField" promptText="https://github.com/username"
                                   style="-fx-pref-height: 36px; -fx-background-radius: 10;
                                          -fx-border-radius: 10; -fx-border-color: #e0e0e0;
                                          -fx-border-width: 1.5; -fx-font-size: 12px;"/>
                    </VBox>
                </HBox>

                <!-- Offer info strip -->
                <HBox fx:id="offerInfoStrip" spacing="16" alignment="CENTER_LEFT"
                      style="-fx-background-color: #fff8f8; -fx-border-color: #fde8e8;
                             -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;
                             -fx-padding: 10 14;">
                    <Label text="🏢" style="-fx-font-size: 14px;"/>
                    <VBox spacing="2">
                        <Label fx:id="offerEstablishment" text=""
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                        <Label fx:id="offerDeadline" text=""
                               style="-fx-font-size: 10px; -fx-text-fill: #e53e3e;"/>
                    </VBox>
                </HBox>

            </VBox>

            <!-- Footer -->
            <HBox alignment="CENTER_RIGHT" spacing="12"
                  style="-fx-background-color: #f9f9f9; -fx-background-radius: 0 0 18 18;
                         -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0; -fx-padding: 16 24;">
                <Button text="Cancel" onAction="#handleClose"
                        style="-fx-background-color: transparent; -fx-text-fill: #666;
                               -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 9 20;
                               -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <Button fx:id="submitBtn" text="Submit Application ✓" onAction="#handleSubmit"
                        style="-fx-background-color: #a12c2f; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-padding: 10 24; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>
