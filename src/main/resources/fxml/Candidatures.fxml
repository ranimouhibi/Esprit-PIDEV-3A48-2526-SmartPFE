<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.CandidatureController">
    <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

    <top>
        <Label text="Application Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    </top>

    <center>
        <SplitPane dividerPositions="0.6">
            <TableView fx:id="candidatureTable">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colStudent" text="Student" prefWidth="150"/>
                    <TableColumn fx:id="colOffer" text="Offer" prefWidth="200"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="130"/>
                </columns>
            </TableView>

            <ScrollPane fitToWidth="true">
                <VBox spacing="10">
                    <padding><Insets top="10" left="15" right="15" bottom="10"/></padding>
                    <Label text="Application Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Label text="Student"/>
                    <Label fx:id="studentLabel" style="-fx-font-weight: bold;"/>

                    <Label text="Offer"/>
                    <Label fx:id="offerLabel" style="-fx-font-weight: bold;"/>

                    <Label text="Status"/>
                    <ComboBox fx:id="statusCombo" maxWidth="Infinity"/>

                    <Label text="Cover letter"/>
                    <TextArea fx:id="motivationField" prefRowCount="4" editable="false" wrapText="true"/>

                    <Label text="Feedback"/>
                    <TextArea fx:id="feedbackField" prefRowCount="3" promptText="Your feedback..."/>

                    <Label fx:id="messageLabel" text="" wrapText="true"/>

                    <HBox spacing="10">
                        <Button text="💾 Update" onAction="#handleUpdate" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button text="🗑 Delete" onAction="#handleDelete" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #FF6B6B; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
