<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.EstablishmentOffersController"
      spacing="0" style="-fx-background-color: #f4f6fb;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Offers Management" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>
            <Label text="View all internship and PFE offers" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
        </VBox>
        <Button fx:id="addBtn" text="+ Add Offer" onAction="#handleToggleForm"
                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 12px;"/>
    </HBox>

    <!-- Stats Bar -->
    <HBox spacing="0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="14" bottom="14" left="30" right="30"/></padding>
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 10 24;">
            <Label fx:id="statTotal" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>
            <Label text="Total" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #a12c2f22; -fx-background-radius: 8; -fx-padding: 10 24;">
            <Label fx:id="statOpen" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
            <Label text="Open" style="-fx-font-size: 10px; -fx-text-fill: #22c55e;"/>
        </VBox>
        <Region prefWidth="12"/>
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #3b82f622; -fx-background-radius: 8; -fx-padding: 10 24;">
            <Label fx:id="statClosed" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #888;"/>
            <Label text="Closed" style="-fx-font-size: 10px; -fx-text-fill: #888;"/>
        </VBox>
    </HBox>

    <!-- Search & Filter -->
    <HBox spacing="12" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="14" bottom="14" left="30" right="30"/></padding>
        <TextField fx:id="searchField" promptText="Search offers..." prefWidth="280"
                   style="-fx-pref-height: 38px; -fx-background-radius: 19; -fx-border-radius: 19; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-padding: 0 16;"/>
        <ComboBox fx:id="filterStatus" prefWidth="140"
                  style="-fx-pref-height: 38px; -fx-background-radius: 8;"/>
        <Button text="Reset" onAction="#handleReset"
                style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 9 20; -fx-cursor: hand;"/>
    </HBox>

    <!-- Scrollable body: form + offers grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="0">

            <!-- Add/Edit Form -->
            <VBox fx:id="formContainer" spacing="16" visible="false" managed="false"
                  style="-fx-background-color: #f0f4ff; -fx-border-color: #667eea; -fx-border-width: 0 0 0 4;">
                <padding><Insets top="20" bottom="20" left="30" right="30"/></padding>
                <Label fx:id="formTitle" text="New Offer" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e1e1e;"/>

                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Title *" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <TextField fx:id="titleField" promptText="Enter offer title"
                                   style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;"/>
                        <Label fx:id="titleError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="160">
                        <Label text="Status" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <ComboBox fx:id="statusCombo" prefWidth="160"
                                  style="-fx-pref-height: 38px; -fx-background-radius: 8;"/>
                    </VBox>
                </HBox>

                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Max Candidates" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <TextField fx:id="maxCandidatesField" text="10"
                                   style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Deadline (dd/MM/yyyy)" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <TextField fx:id="deadlineField" promptText="31/12/2025"
                                   style="-fx-pref-height: 38px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Description *" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <TextArea fx:id="descriptionField" promptText="Describe the offer..." prefRowCount="3"
                              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;"/>
                    <Label fx:id="descError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                </VBox>

                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Objectives" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <TextArea fx:id="objectivesField" promptText="Project objectives..." prefRowCount="2"
                                  style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Required Skills" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <TextArea fx:id="skillsField" promptText="Java, Spring, MySQL..." prefRowCount="2"
                                  style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Cancel" onAction="#handleCancelForm"
                            style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-cursor: hand; -fx-font-size: 12px;"/>
                    <Button text="Save Offer" onAction="#handleSave"
                            style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Offers Grid -->
            <VBox spacing="20">
                <padding><Insets top="24" bottom="24" left="30" right="30"/></padding>
                <FlowPane fx:id="offersContainer" hgap="20" vgap="20" prefWrapLength="1000"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
