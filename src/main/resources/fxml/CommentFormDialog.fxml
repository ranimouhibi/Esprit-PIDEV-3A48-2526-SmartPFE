<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.CommentFormDialogController"
      spacing="0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 25, 0, 0, 5);">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #2d2d2d; -fx-background-radius: 16 16 0 0; -fx-padding: 20 24;">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label fx:id="dialogTitle" text="Add Comment"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Share your thoughts on the project"
                   style="-fx-font-size: 12px; -fx-text-fill: #bbb;"/>
        </VBox>
    </HBox>
    
    <!-- Form Content -->
    <VBox spacing="20">
        <padding><Insets top="24" bottom="30" left="35" right="35"/></padding>

        <!-- Form Fields -->
        <ScrollPane fitToWidth="true" prefHeight="480" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="16">
                <!-- Project -->
                <VBox spacing="6">
                    <Label text="Project *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                    <ComboBox fx:id="projectCombo" promptText="Select project" maxWidth="Infinity"
                              style="-fx-pref-height: 42px; -fx-background-radius: 8;"/>
                    <Label fx:id="projectError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Subject -->
                <VBox spacing="6">
                    <Label text="Subject *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                    <TextField fx:id="subjectField" promptText="Enter subject"
                               style="-fx-pref-height: 42px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-padding: 0 14;"/>
                    <Label fx:id="subjectError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Content -->
                <VBox spacing="6">
                    <Label text="Comment *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                    <TextArea fx:id="contentField" promptText="Write your comment..."
                              prefRowCount="4" wrapText="true"
                              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-padding: 10 14;"/>
                    <Label fx:id="contentError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Comment Type -->
                <VBox spacing="6">
                    <Label text="Comment Type *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                    <ComboBox fx:id="typeCombo" promptText="Select type" maxWidth="Infinity"
                              style="-fx-pref-height: 42px; -fx-background-radius: 8;"/>
                    <Label fx:id="typeError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Target -->
                <VBox spacing="6">
                    <Label text="Target *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                    <ComboBox fx:id="targetCombo" promptText="Select target" maxWidth="Infinity"
                              style="-fx-pref-height: 42px; -fx-background-radius: 8;"/>
                    <Label fx:id="targetError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Importance -->
                <VBox spacing="6">
                    <Label text="Importance *" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                    <ComboBox fx:id="importanceCombo" promptText="Select importance" maxWidth="Infinity"
                              style="-fx-pref-height: 42px; -fx-background-radius: 8;"/>
                    <Label fx:id="importanceError" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </VBox>
            </VBox>
        </ScrollPane>

        <!-- Error Message -->
        <Label fx:id="errorLabel" text="" wrapText="true"
               style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-color: #fee2e2; -fx-background-radius: 8; -fx-padding: 12;" visible="false"/>

        <!-- Buttons -->
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Cancel" onAction="#handleCancel"
                    style="-fx-background-color: #f3f4f6; -fx-text-fill: #666; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 28; -fx-cursor: hand; -fx-font-size: 13px;"/>
            <Button fx:id="saveButton" text="Add Comment" onAction="#handleSave"
                    style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 28; -fx-cursor: hand; -fx-font-size: 13px; -fx-effect: dropshadow(gaussian, rgba(161,44,47,0.35), 10, 0, 0, 3);"/>
        </HBox>
    </VBox>

</VBox>
