<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.MeetingFollowUpEmailController"
      spacing="0" style="-fx-background-color:#f0f2f5;" prefWidth="520" prefHeight="560">

    <!-- Header -->
    <VBox style="-fx-background-color:#1e1e2e;" spacing="4">
        <padding><Insets top="16" bottom="16" left="20" right="20"/></padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="📧 Email de Suivi" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeBtn" text="✕" onAction="#handleClose"
                    style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-background-radius:6;-fx-cursor:hand;-fx-padding:4 10;"/>
        </HBox>
        <Label fx:id="meetingTitleLabel" text="" style="-fx-font-size:11px;-fx-text-fill:#8b8fa8;"/>
    </VBox>

    <VBox spacing="14" VBox.vgrow="ALWAYS">
        <padding><Insets top="20" bottom="16" left="20" right="20"/></padding>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="generateBtn" text="🤖 Générer avec AI" onAction="#handleGenerate"
                    style="-fx-background-color:#374151;-fx-text-fill:white;-fx-font-weight:bold;
                           -fx-background-radius:8;-fx-cursor:hand;-fx-padding:8 16;"/>
            <Label text="ou écrivez directement ci-dessous" style="-fx-text-fill:#6b7280;-fx-font-size:12px;"/>
        </HBox>

        <Label fx:id="statusLabel" text="" style="-fx-font-size:11px;-fx-text-fill:#8b8fa8;" wrapText="true"/>

        <TextArea fx:id="emailBodyArea" VBox.vgrow="ALWAYS"
                  promptText="L'email de suivi apparaîtra ici. Vous pouvez aussi l'écrire manuellement."
                  style="-fx-background-radius:8;-fx-border-radius:8;-fx-border-color:#d1d5db;
                         -fx-font-size:13px;-fx-padding:10;"/>
    </VBox>

    <!-- Footer -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-background-color:white;-fx-border-color:#e5e7eb;-fx-border-width:1 0 0 0;">
        <padding><Insets top="14" bottom="14" left="20" right="20"/></padding>
        <Button text="Annuler" onAction="#handleClose"
                style="-fx-background-color:#f3f4f6;-fx-background-radius:8;-fx-cursor:hand;-fx-padding:8 20;"/>
        <Button fx:id="sendBtn" text="📤 Envoyer aux participants" onAction="#handleSend"
                style="-fx-background-color:#a12c2f;-fx-text-fill:white;-fx-font-weight:bold;
                       -fx-background-radius:8;-fx-cursor:hand;-fx-padding:8 20;"/>
    </HBox>
</VBox>
