<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.CandidaturesByOfferController">
    <padding><Insets top="16" left="16" right="16" bottom="16"/></padding>

    <top>
        <VBox spacing="8">
            <Label fx:id="offerTitleLabel" text="Candidatures"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Double-click a row to view full detail. Select multiple (Ctrl+Click) to compare."
                   style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
            <padding><Insets bottom="6"/></padding>
        </VBox>
    </top>

    <center>
        <TableView fx:id="candidatureTable" selectionMode="MULTIPLE">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colStudent" text="Student" prefWidth="200"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                <TableColumn fx:id="colDate" text="Applied On" prefWidth="130"/>
            </columns>
            <placeholder><Label text="No candidatures for this offer"/></placeholder>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10">
            <padding><Insets top="10"/></padding>
            <Button text="👁 Open Detail" onAction="#handleOpenDetail"
                    style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 16;"/>
            <Button fx:id="btnCompare" text="⚖ Compare Selected" onAction="#handleCompare"
                    style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 16;"/>
        </HBox>
    </bottom>
</BorderPane>
