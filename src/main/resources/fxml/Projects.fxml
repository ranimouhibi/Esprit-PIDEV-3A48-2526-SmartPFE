<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ProjectController">
    <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>

    <top>
        <VBox spacing="10">
            <Label text="Project Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search a project..." prefWidth="250"/>
                <Button text="🔍 Search" onAction="#handleSearch" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 6;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.6">
            <!-- Table -->
            <TableView fx:id="projectTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colTitle" text="Title" prefWidth="200"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="colOwner" text="Student" prefWidth="150"/>
                    <TableColumn fx:id="colSupervisor" text="Supervisor" prefWidth="150"/>
                </columns>
            </TableView>

            <!-- Form -->
            <ScrollPane fitToWidth="true">
                <VBox spacing="12">
                    <padding><Insets top="10" left="15" right="15" bottom="10"/></padding>
                    <Label text="Project Form" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Label text="Title *"/>
                    <TextField fx:id="titleField" promptText="Project title"/>

                    <Label text="Description"/>
                    <TextArea fx:id="descriptionField" promptText="Description..." prefRowCount="3"/>

                    <Label text="Type"/>
                    <ComboBox fx:id="typeCombo" maxWidth="Infinity"/>

                    <Label text="Status"/>
                    <ComboBox fx:id="statusCombo" maxWidth="Infinity"/>

                    <Label text="Student (owner)"/>
                    <ComboBox fx:id="ownerCombo" maxWidth="Infinity"/>

                    <Label text="Supervisor"/>
                    <ComboBox fx:id="supervisorCombo" maxWidth="Infinity"/>

                    <Label fx:id="messageLabel" text="" wrapText="true"/>

                    <HBox spacing="10">
                        <Button text="💾 Save" onAction="#handleSave" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button text="🗑 Delete" onAction="#handleDelete" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #FF6B6B; -fx-text-fill: white; -fx-background-radius: 6;"/>
                        <Button text="✖ Clear" onAction="#handleClear" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #aaa; -fx-text-fill: white; -fx-background-radius: 6;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
