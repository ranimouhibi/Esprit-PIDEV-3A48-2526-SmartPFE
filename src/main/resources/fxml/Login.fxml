<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.controller.LoginController"
           style="-fx-background-color: #2d2d2d;">

    <VBox alignment="CENTER" spacing="0" maxWidth="380" maxHeight="480"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 5);">
        <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

        <!-- Header -->
        <VBox spacing="8" alignment="CENTER">
            <Label text="Smart-PFE" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #a12c2f;"/>
            <Label text="Sign in to continue" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
        </VBox>

        <VBox spacing="20" VBox.vgrow="ALWAYS">
            <padding><Insets top="30"/></padding>

            <!-- Email Field -->
            <VBox spacing="8">
                <Label text="Email" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                <TextField fx:id="emailField" promptText="name@example.com"
                           style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Password Field -->
            <VBox spacing="8">
                <Label text="Password" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22; -fx-border-color: #ddd; -fx-border-width: 1.5; -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Remember me & Forgot password -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <CheckBox text="Remember me" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label text="Forgot password?" onMouseClicked="#goToForgotPassword"
                       style="-fx-text-fill: #a12c2f; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Error Label -->
            <Label fx:id="errorLabel" text="" style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" alignment="CENTER"/>

            <!-- Sign In Button -->
            <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin"
                    maxWidth="Infinity" prefHeight="46"
                    style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 23; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(161,44,47,0.3), 8, 0, 0, 2);"/>

            <!-- Sign up link -->
            <HBox alignment="CENTER" spacing="4">
                <padding><Insets top="8"/></padding>
                <Label text="Don't have an account?" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                <Label text="Sign up" onMouseClicked="#goToSignup"
                       style="-fx-text-fill: #a12c2f; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>

    </VBox>

</StackPane>
