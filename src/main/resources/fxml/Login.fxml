<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.controller.LoginController"
           style="-fx-background-color: #2d2d2d;">

    <!-- ══════════════════════════════════════════════════════════
         PANEL A — Standard email / password login
         ══════════════════════════════════════════════════════════ -->
    <VBox fx:id="passwordPanel" alignment="CENTER" spacing="0" maxWidth="380"
          style="-fx-background-color: white; -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 5);">
        <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

        <VBox spacing="8" alignment="CENTER">
            <Label text="Smart-PFE"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #a12c2f;"/>
            <Label text="Sign in to continue"
                   style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
        </VBox>

        <VBox spacing="20">
            <padding><Insets top="30"/></padding>

            <VBox spacing="8">
                <Label text="Email"
                       style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                <TextField fx:id="emailField" promptText="name@example.com"
                           style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22;
                                  -fx-border-color: #ddd; -fx-border-width: 1.5;
                                  -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Password"
                       style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #333;"/>
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-pref-height: 44px; -fx-background-radius: 22; -fx-border-radius: 22;
                                      -fx-border-color: #ddd; -fx-border-width: 1.5;
                                      -fx-background-color: #f9f9f9; -fx-padding: 0 18; -fx-font-size: 13px;"/>
            </VBox>

            <HBox alignment="CENTER_LEFT">
                <CheckBox fx:id="rememberMeCheck" text="Remember me"
                          style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label text="Forgot password?" onMouseClicked="#goToForgotPassword"
                       style="-fx-text-fill: #a12c2f; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;"
                   wrapText="true" alignment="CENTER"/>

            <Button text="Sign In" onAction="#handleLogin"
                    maxWidth="Infinity" prefHeight="46"
                    style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-size: 14px;
                           -fx-font-weight: bold; -fx-background-radius: 23; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(161,44,47,0.3), 8, 0, 0, 2);"/>

            <!-- Switch to PIN panel (only shown when a PIN is set) -->
            <Button fx:id="switchToPinBtn" text="🔢  Use PIN instead"
                    onAction="#showPinPanel"
                    maxWidth="Infinity" prefHeight="40"
                    managed="false" visible="false"
                    style="-fx-background-color: #f4f6fb; -fx-text-fill: #333; -fx-font-size: 13px;
                           -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;
                           -fx-border-color: #ddd; -fx-border-radius: 20; -fx-border-width: 1.5;"/>

            <HBox alignment="CENTER" spacing="4">
                <padding><Insets top="4"/></padding>
                <Label text="Don't have an account?" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                <Label text="Sign up" onMouseClicked="#goToSignup"
                       style="-fx-text-fill: #a12c2f; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- ══════════════════════════════════════════════════════════
         PANEL B — PIN login
         ══════════════════════════════════════════════════════════ -->
    <VBox fx:id="pinPanel" alignment="CENTER" spacing="0" maxWidth="340"
          managed="false" visible="false"
          style="-fx-background-color: white; -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 5);">
        <padding><Insets top="36" bottom="36" left="36" right="36"/></padding>

        <!-- Header -->
        <VBox spacing="6" alignment="CENTER">
            <Label text="Smart-PFE"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #a12c2f;"/>
            <!-- Avatar circle with initials -->
            <StackPane prefWidth="72" prefHeight="72" minWidth="72" minHeight="72"
                       maxWidth="72" maxHeight="72"
                       style="-fx-background-color: #a12c2f; -fx-background-radius: 36;">
                <Label fx:id="pinAvatarLabel" text="?"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </StackPane>
            <Label fx:id="pinUserName" text=""
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #222;"/>
            <Label text="Enter your PIN"
                   style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
        </VBox>

        <VBox spacing="20">
            <padding><Insets top="24"/></padding>

            <!-- 4-dot indicator -->
            <HBox fx:id="pinDots" spacing="16" alignment="CENTER">
                <StackPane prefWidth="18" prefHeight="18"
                           style="-fx-background-color: #ddd; -fx-background-radius: 9;"/>
                <StackPane prefWidth="18" prefHeight="18"
                           style="-fx-background-color: #ddd; -fx-background-radius: 9;"/>
                <StackPane prefWidth="18" prefHeight="18"
                           style="-fx-background-color: #ddd; -fx-background-radius: 9;"/>
                <StackPane prefWidth="18" prefHeight="18"
                           style="-fx-background-color: #ddd; -fx-background-radius: 9;"/>
                <StackPane prefWidth="18" prefHeight="18"
                           style="-fx-background-color: #ddd; -fx-background-radius: 9;"/>
                <StackPane prefWidth="18" prefHeight="18"
                           style="-fx-background-color: #ddd; -fx-background-radius: 9;"/>
            </HBox>

            <!-- Error -->
            <Label fx:id="pinErrorLabel" text=""
                   style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;"
                   alignment="CENTER" maxWidth="Infinity"
                   managed="false" visible="false"/>

            <!-- Numpad -->
            <GridPane hgap="12" vgap="12" alignment="CENTER">
                <!-- Row 1: 1 2 3 -->
                <Button text="1" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="0" GridPane.rowIndex="0"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <Button text="2" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="1" GridPane.rowIndex="0"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <Button text="3" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="2" GridPane.rowIndex="0"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <!-- Row 2: 4 5 6 -->
                <Button text="4" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="0" GridPane.rowIndex="1"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <Button text="5" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="1" GridPane.rowIndex="1"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <Button text="6" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="2" GridPane.rowIndex="1"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <!-- Row 3: 7 8 9 -->
                <Button text="7" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="0" GridPane.rowIndex="2"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <Button text="8" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="1" GridPane.rowIndex="2"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <Button text="9" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="2" GridPane.rowIndex="2"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <!-- Row 4: ← 0 ✓ -->
                <Button text="⌫" onAction="#pinBackspace" prefWidth="72" prefHeight="52" GridPane.columnIndex="0" GridPane.rowIndex="3"
                        style="-fx-font-size: 18px; -fx-background-color: #fff0f0; -fx-text-fill: #a12c2f; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #fca5a5; -fx-border-radius: 12;"/>
                <Button text="0" onAction="#pinKey" prefWidth="72" prefHeight="52" GridPane.columnIndex="1" GridPane.rowIndex="3"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #f4f6fb; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e0e0e0; -fx-border-radius: 12;"/>
                <Button text="✓" onAction="#pinConfirm" prefWidth="72" prefHeight="52" GridPane.columnIndex="2" GridPane.rowIndex="3"
                        style="-fx-font-size: 18px; -fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;"/>
            </GridPane>

            <!-- Switch back to password -->
            <Label text="Use password instead" onMouseClicked="#showPasswordPanel"
                   alignment="CENTER" maxWidth="Infinity"
                   style="-fx-text-fill: #a12c2f; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-weight: bold;"/>
        </VBox>
    </VBox>

</StackPane>
