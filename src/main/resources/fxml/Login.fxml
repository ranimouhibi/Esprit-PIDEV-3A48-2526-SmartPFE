<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.LoginController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #1a1a2e;">

    <center>
        <VBox alignment="CENTER" spacing="20" maxWidth="400">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>
            <style>-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 5);</style>

            <Label text="SmartPFE" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #a12c2f;"/>
            <Label text="Gestion de Projets de Fin d'Études" style="-fx-font-size: 13px; -fx-text-fill: #666;"/>

            <Separator/>

            <VBox spacing="5">
                <Label text="Email" style="-fx-font-weight: bold;"/>
                <TextField fx:id="emailField" promptText="votre@email.com"
                           style="-fx-pref-height: 40px; -fx-border-radius: 8; -fx-background-radius: 8;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Mot de passe" style="-fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-pref-height: 40px; -fx-border-radius: 8; -fx-background-radius: 8;"/>
            </VBox>

            <Label fx:id="errorLabel" text="" style="-fx-text-fill: red; -fx-font-size: 12px;" wrapText="true"/>

            <Button fx:id="loginButton" text="Se connecter" onAction="#handleLogin"
                    maxWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: #a12c2f; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </center>
</BorderPane>
